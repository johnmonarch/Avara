{
  "name": "avara-web-workspace",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev:web-player": "pnpm --filter @avara/web-player dev",
    "dev:admin": "pnpm --filter @avara/admin dev",
    "dev:api": "node apps/api/src/server.ts",
    "dev:matchmaker": "node apps/matchmaker/src/server.ts",
    "dev:game-server": "node apps/game-server/src/server.ts",
    "build:web-player": "pnpm --filter @avara/web-player build",
    "build:admin": "pnpm --filter @avara/admin build"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
